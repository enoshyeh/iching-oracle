# Database (SQLite for local dev only — use PostgreSQL on Vercel)
DATABASE_URL="file:./dev.db"

# Required — generate with: openssl rand -base64 32
AUTH_SECRET=

# Production canonical URL (must match the domain users open in the browser)
# Local:  http://localhost:3000
# Live:   https://www.ichingoracle.de
# IMPORTANT: Do NOT leave localhost on Vercel — it breaks Google OAuth.
AUTH_URL=http://localhost:3000

# Optional on Vercel if AUTH_URL is correct; set to true to trust x-forwarded-host
# AUTH_TRUST_HOST=true

# Google OAuth — both required for Google sign-in
# Console: https://console.cloud.google.com/apis/credentials
# Redirect URI must include: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Legacy aliases (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# PostgreSQL example for Vercel production
# DATABASE_URL="postgresql://user:password@host:5432/iching_oracle?sslmode=require"

# Future Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
